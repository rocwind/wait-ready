  },
  "homepage": "https://github.com/rocwind/wait-ready#readme",
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@rollup/plugin-babel": "7.0.0",
    "@types/jest": "30.0.0",
    "jest": "30.3.0",
    "rollup": "2.80.0",
    "standard-version": "9.5.0",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  }
